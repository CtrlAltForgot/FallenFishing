$Common = "Common.ui";

Group {
  LayoutMode: Top;
  Anchor: (Width: 700, Height: 74);

  Group #Card {
    LayoutMode: Left;
    Anchor: (Width: 700, Height: 66);
    Background: $Common.@InputBoxBackground;
    Padding: (Left: 14, Right: 14, Top: 8, Bottom: 6);

    ItemIcon #Icon {
      Anchor: (Width: 42, Height: 42);
    }

    Group #Stats {
      LayoutMode: Top;
      Anchor: (Left: 12, Width: 618, Height: 48);

      Group #Header {
        LayoutMode: Left;
        Anchor: (Width: 618, Height: 20);

        Label #Name {
          Style: (FontSize: 17, RenderBold: true);
          Anchor: (Right: 8);
          Text: "Fish Name";
        }

        Label #Rarity {
          Style: (FontSize: 12, RenderBold: true, TextColor: #ffffff(0.90));
          Text: "Common";
        }
      }

      Group { Anchor: (Width: 1, Height: 5); }

      Group #Details {
        LayoutMode: Left;
        Anchor: (Width: 618, Height: 18);

        Label #Length {
          Style: (FontSize: 12, TextColor: #ffffff(0.85));
          Anchor: (Right: 18);
          Text: "Length: 0.00 cm";
        }

        Label #Weight {
          Style: (FontSize: 12, TextColor: #ffffff(0.85));
          Anchor: (Right: 18);
          Text: "Weight: 0.00 kg";
        }

        Label #Date {
          Style: (FontSize: 12, TextColor: #ffffff(0.78));
          Text: "Date: 2026-04-02 23:58";
        }
      }
    }
  }
}
