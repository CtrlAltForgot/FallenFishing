$Common = "Common.ui";

Group {
  LayoutMode: Top;
  Anchor: (Width: 700, Height: 106);

  Group #Card {
    LayoutMode: Left;
    Anchor: (Width: 700, Height: 98);
    Background: $Common.@InputBoxBackground;
    Padding: (Left: 14, Right: 14, Top: 10, Bottom: 8);

    ItemIcon #Icon {
      Anchor: (Width: 42, Height: 42);
    }

    Group #Stats {
      LayoutMode: Top;
      Anchor: (Left: 12, Width: 618, Height: 78);

      Label #Name {
        Style: (FontSize: 17, RenderBold: true);
        Text: "Fish Name";
      }

      Group { Anchor: (Width: 1, Height: 6); }

      Group #LongestRow {
        LayoutMode: Left;
        Anchor: (Width: 618, Height: 18);

        Label #LongestLength {
          Style: (FontSize: 12, TextColor: #ffffff(0.85));
          Anchor: (Right: 18);
          Text: "Longest Length: ???";
        }

        Label #LongestCaughtBy {
          Style: (FontSize: 12, TextColor: #ffffff(0.78));
          Anchor: (Right: 18);
          Text: "Caught By: ???";
        }

        Label #LongestDate {
          Style: (FontSize: 12, TextColor: #ffffff(0.78));
          Text: "Date: ???";
        }
      }

      Group { Anchor: (Width: 1, Height: 5); }

      Group #HeaviestRow {
        LayoutMode: Left;
        Anchor: (Width: 618, Height: 18);

        Label #HeaviestWeight {
          Style: (FontSize: 12, TextColor: #ffffff(0.85));
          Anchor: (Right: 18);
          Text: "Heaviest Weight: ???";
        }

        Label #HeaviestCaughtBy {
          Style: (FontSize: 12, TextColor: #ffffff(0.78));
          Anchor: (Right: 18);
          Text: "Caught By: ???";
        }

        Label #HeaviestDate {
          Style: (FontSize: 12, TextColor: #ffffff(0.78));
          Text: "Date: ???";
        }
      }
    }
  }
}
